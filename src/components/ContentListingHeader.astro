---
/**
 * The mono-font [ ARCHIVE.INDEX // NN ] label and corner crosses shared by
 * every paginated listing page (note and jotting).
 *
 * `index` is the section's ordinal in the site shell, used for the numeric
 * badge; `label` is the user-visible section name (uppercased in the template).
 */
export interface Props {
	index: number;
	label: string;
}

const { index, label } = Astro.props;
const padded = String(index).padStart(2, "0");
---

<header class="flex flex-col gap-2 mb-10 border-b border-weak/10 pb-6 relative">
	<!-- Corner Marks -->
	<span class="absolute -bottom-1 -left-1 text-[8px] font-mono text-weak/40">+</span>
	<span class="absolute -bottom-1 -right-1 text-[8px] font-mono text-weak/40">+</span>

	<div class="flex items-center gap-2 text-[10px] font-mono text-weak uppercase tracking-widest">
		<span>[ ARCHIVE.INDEX // {padded} ]</span>
		<span class="h-px w-8 bg-weak/20"></span>
		<span>{label.toUpperCase()}</span>
	</div>
</header>
