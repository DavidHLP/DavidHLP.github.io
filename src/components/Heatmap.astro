---
import { Temporal } from "temporal-polyfill";
import config from "$config";
import { getStrategy, type HeatmapBin, type HeatmapConfig, type HeatmapUnit } from "$utils/heatmap-bins";
import type { ContentCard } from "$utils/content";
import { ts } from "$utils/labels";
import Time from "$utils/time";
import i18nit from "$i18n";

/**
 * Heatmap component props.
 *
 * The input is the same `ContentCard[]` shape the listing pages, the
 * Atom feed, and `<LatestCard />` consume. The pre-deepening module
 * took parallel `notes` / `jottings` raw-entry arrays and re-shaped
 * them via `toHeatmapEntries`; the deepening collapses that into a
 * single `cards` input so the data shape lives in one place.
 */
interface Props {
	locale: string;
	cards: ContentCard[];
}

let { locale, cards } = Astro.props;

// Initialise the translation function for the popup labels.
const t = i18nit(locale);

// Pick the strategy once at the seam; the rest of the component never
// branches on `unit`. The strategy owns the grid class, the per-cell
// size class, the popup-rendering shape, and the bin construction.
const unit: HeatmapUnit = config.heatmap?.unit ?? "day";
const strategy = getStrategy(unit);
const heatmapConfig: HeatmapConfig = config.heatmap ?? { unit: "day" };
const now: Temporal.PlainDate = Time().toPlainDate();

// Build the bins. The pipeline (init empty bins, distribute entries)
// is the strategy's job; this component just renders. The strategy's
// `showEntryTitles` discriminator decides whether the cell popup lists
// each card's title with a link (day / week) or just an aggregate
// count (month), so the if-ladder below never inspects `unit` directly.
const cells: HeatmapBin[] = strategy.buildBins(cards, now, heatmapConfig, locale);
const showTitles = strategy.showEntryTitles;
---

<section class:list={["grid gap-1", strategy.gridClass]}>
	{
		cells.map(cell => {
			const count = cell.contents.length;
			const details = [];

			// Generate details for the popup based on cell content
			if (count) {
				const notes = cell.contents.filter(card => card.section === "note");
				const jottings = cell.contents.filter(card => card.section === "jotting");

				if (notes.length) {
					if (showTitles) {
						details.push(
							<p class="my-1">{ts(t, "home.heatmap.note", { count: notes.length })}：</p>,
							<ul class="flex flex-col gap-0.5">
								{notes.map(note => (
									<li>
										<a href={note.url} aria-label={note.data.title} class="ms-1 link">
											{note.data.title}
										</a>
									</li>
								))}
							</ul>
						);
					} else {
						details.push(<p>{ts(t, "home.heatmap.note", { count: notes.length })}</p>);
					}
				}

				if (jottings.length) {
					if (showTitles) {
						details.push(
							<p class="my-1">{ts(t, "home.heatmap.jotting", { count: jottings.length })}：</p>,
							<ul class="flex flex-col gap-0.5">
								{jottings.map(jotting => (
									<li>
										<a href={jotting.url} aria-label={jotting.data.title} class="ms-1 link">
											{jotting.data.title}
										</a>
									</li>
								))}
							</ul>
						);
					} else {
						details.push(<p>{ts(t, "home.heatmap.jotting", { count: jottings.length })}</p>);
					}
				}
			} else {
				// Display empty message if no content
				details.push(<p class="mt-1">{ts(t, "home.heatmap.empty")}</p>);
			}

			return (
				<figure class="group/pop">
					<i class:list={["block bg-primary/10", strategy.cellSizeClass, { "bg-primary/40": count > 0, "bg-primary/70": count > 1, "bg-primary": count > 2 }]} />

					<div class="w-max flex flex-col mb-1 rounded-sm px-2 py-2 text-xs text-background bg-primary pop">
						<time class="font-bold">{cell.target}</time>
						{details}
					</div>
				</figure>
			);
		})
	}
</section>

<style>
	@supports (anchor-name: --anchor-heatmap) {
		figure {
			anchor-scope: --anchor-heatmap;

			i {
				anchor-name: --anchor-heatmap;
			}

			.pop {
				position: fixed;
				position-anchor: --anchor-heatmap;
				position-area: top;
				justify-self: anchor-center;
				z-index: 10;
			}
		}
	}

	@supports not (anchor-name: --anchor-heatmap) {
		figure {
			position: relative;

			.pop {
				position: absolute;
				bottom: 100%;
				inset-inline-start: 0;
				transform: translateX(-50%);
			}
		}

		figure .pop:dir(rtl) {
			transform: translateX(50%);
		}
	}
</style>
