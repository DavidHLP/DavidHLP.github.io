---
import { Temporal } from "temporal-polyfill";
import config from "$config";
import { getStrategy, toHeatmapEntries, type HeatmapBin, type HeatmapConfig, type HeatmapUnit } from "$utils/heatmap-bins";
import { ts } from "$utils/labels";
import Time from "$utils/time";
import i18nit from "$i18n";

/**
 * Heatmap component props
 */
interface Props {
	locale: string;
	notes: { id: string; data: { title: string; timestamp: Date } }[];
	jottings: { id: string; data: { title: string; timestamp: Date } }[];
}

let { locale, notes, jottings } = Astro.props;

// Initialise the translation function for the popup labels.
const t = i18nit(locale);

// Pick the strategy once at the seam; the rest of the component never
// branches on `unit`. The strategy owns the grid class, the per-cell
// size class, and the bin construction.
const unit: HeatmapUnit = config.heatmap?.unit ?? "day";
const strategy = getStrategy(unit);
const heatmapConfig: HeatmapConfig = config.heatmap ?? { unit: "day" };
const now: Temporal.PlainDate = Time().toPlainDate();

// Normalise entries through the seam.
const entries = toHeatmapEntries(notes, jottings, locale);

// Build the bins. The pipeline (init empty bins, distribute entries)
// is now the strategy's job; this component just renders.
const cells: HeatmapBin[] = strategy.buildBins(entries, now, heatmapConfig, locale);
---

<section class:list={["grid gap-1", strategy.gridClass]}>
	{
		cells.map(cell => {
			const count = cell.contents.length;
			const details = [];

			// Generate details for the popup based on cell content
			if (count) {
				const notes = cell.contents.filter(content => content.section === "note");
				const jottings = cell.contents.filter(content => content.section === "jotting");

				if (notes.length) {
					if (unit === "month") {
						details.push(<p>{ts(t, "home.heatmap.note", { count: notes.length })}</p>);
					} else {
						details.push(
							<p class="my-1">{ts(t, "home.heatmap.note", { count: notes.length })}：</p>,
							<ul class="flex flex-col gap-0.5">
								{notes.map(note => (
									<li>
										<a href={note.link} aria-label={note.title} class="ms-1 link">
											{note.title}
										</a>
									</li>
								))}
							</ul>
						);
					}
				}

				if (jottings.length) {
					if (unit === "month") {
						details.push(<p>{ts(t, "home.heatmap.jotting", { count: jottings.length })}</p>);
					} else {
						details.push(
							<p class="my-1">{ts(t, "home.heatmap.jotting", { count: jottings.length })}：</p>,
							<ul class="flex flex-col gap-0.5">
								{jottings.map(jotting => (
									<li>
										<a href={jotting.link} aria-label={jotting.title} class="ms-1 link">
											{jotting.title}
										</a>
									</li>
								))}
							</ul>
						);
					}
				}
			} else {
				// Display empty message if no content
				details.push(<p class="mt-1">{ts(t, "home.heatmap.empty")}</p>);
			}

			return (
				<figure class="group/pop">
					<i class:list={["block bg-primary/10", strategy.cellSizeClass, { "bg-primary/40": count > 0, "bg-primary/70": count > 1, "bg-primary": count > 2 }]} />

					<div class="w-max flex flex-col mb-1 rounded-sm px-2 py-2 text-xs text-background bg-primary pop">
						<time class="font-bold">{cell.target}</time>
						{details}
					</div>
				</figure>
			);
		})
	}
</section>

<style>
	@supports (anchor-name: --anchor-heatmap) {
		figure {
			anchor-scope: --anchor-heatmap;

			i {
				anchor-name: --anchor-heatmap;
			}

			.pop {
				position: fixed;
				position-anchor: --anchor-heatmap;
				position-area: top;
				justify-self: anchor-center;
				z-index: 10;
			}
		}
	}

	@supports not (anchor-name: --anchor-heatmap) {
		figure {
			position: relative;

			.pop {
				position: absolute;
				bottom: 100%;
				inset-inline-start: 0;
				transform: translateX(-50%);
			}
		}

		figure .pop:dir(rtl) {
			transform: translateX(50%);
		}
	}
</style>
