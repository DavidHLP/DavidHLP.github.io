---
import { render } from "astro:content";
import config from "$config";
import { listPrefaces, localeStaticPaths } from "$utils/content";
import Time from "$utils/time";
import Base from "$layouts/Base.astro";
import i18nit from "$i18n";
import { ts } from "$utils/labels";

export const getStaticPaths = localeStaticPaths;

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

// Route through the preface seam so the locale-filter + sort by
// timestamp desc lives in one place (the previous inline version
// was duplicated in `index.astro` and `preface.astro`).
const prefaces = await listPrefaces(locale);

// Render each entry
const entries = await Promise.all(prefaces.map(async preface => ({ ...preface, content: (await render(preface)).Content })));
---

<Base title={ts(t, "navigation.preface")} {locale}>
	<main class="flex flex-col">
		<h2>{ts(t, "home.prefaces")}</h2>
		<ul class="flex flex-col list-none">
			{
				entries.map(preface => [
					<hr class="my-5 border-b border-primary" />,
					<li>
						<time datetime={preface.data.timestamp.toISOString()} class="block mb-5 font-bold text-xl">
							{Time.toLocaleString(preface.data.timestamp, locale)}
						</time>
						<article class="markdown">
							<preface.content />
						</article>
						{preface.data.author && (
							<div class="mt-2 text-right text-xs font-mono text-weak pr-4">
								— {preface.data.author}
							</div>
						)}
					</li>
				])
			}
		</ul>
	</main>
</Base>
