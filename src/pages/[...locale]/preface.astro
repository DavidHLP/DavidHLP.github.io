---
import { render } from "astro:content";
import config from "$config";
import { getPublishedByLocale, localeStaticPaths } from "$utils/content";
import Time from "$utils/time";
import Base from "$layouts/Base.astro";
import i18nit from "$i18n";

export const getStaticPaths = localeStaticPaths;

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

// Route through `getPublishedByLocale` so Preface shares the same locale-filter
// seam as Note and Jotting; the input entries stay immutable.
const prefaces = (await getPublishedByLocale("preface", locale)).sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

// Render each entry
const entries = await Promise.all(prefaces.map(async preface => ({ ...preface, content: (await render(preface)).Content })));
---

<Base title={t("navigation.preface")} {locale}>
	<main class="flex flex-col">
		<h2>{t("home.prefaces")}</h2>
		<ul class="flex flex-col list-none">
			{
				entries.map(preface => [
					<hr class="my-5 border-b border-primary" />,
					<li>
						<time datetime={preface.data.timestamp.toISOString()} class="block mb-5 font-bold text-xl">
							{Time.toLocaleString(preface.data.timestamp, locale)}
						</time>
						<article class="markdown">
							<preface.content />
						</article>
						{preface.data.author && (
							<div class="mt-2 text-right text-xs font-mono text-weak pr-4">
								— {preface.data.author}
							</div>
						)}
					</li>
				])
			}
		</ul>
	</main>
</Base>
