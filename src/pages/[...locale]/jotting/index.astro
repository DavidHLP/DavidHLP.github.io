---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import config, { monolocale } from "$config";
import Base from "$layouts/Base.astro";
import Jotting from "$components/Jotting.svelte";
import i18nit from "$i18n";

export async function getStaticPaths() {
	// Create path for each locale, omitting default locale from URL
	return config.i18n.locales.map(locale => ({ params: { locale: config.i18n.defaultLocale === locale ? undefined : locale } }));
}

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

const jottings = await getCollection("jotting", jotting => {
	// Filter by publication status and locale
	let published = !jotting.data.draft;
	let localed = monolocale || jotting.id.split("/")[0] === locale;

	return published && localed;
});

// Standardize note structure
let list = jottings.map(jotting => ({
	id: jotting.id,
	url: getRelativeLocaleUrl(locale, `/jotting/${monolocale ? jotting.id : jotting.id.split("/").slice(1).join("/")}`),
	data: {
		title: jotting.data.title,
		timestamp: jotting.data.timestamp,
		tags: jotting.data.tags,
		sensitive: jotting.data.sensitive,
		top: jotting.data.top
	}
}));

// Extract all unique tags from the filtered notes
const tags = Array.from(new Set(jottings.flatMap(jotting => jotting.data.tags).filter((tag): tag is string => Boolean(tag)))).sort();
---

<Base title={t("navigation.jotting")} {locale}>
	<main class="flex flex-col grow py-4">
		<!-- Page Header -->
		<header class="flex flex-col gap-2 mb-10 border-b border-weak/10 pb-6 relative">
			<!-- Corner Marks -->
			<span class="absolute -bottom-1 -left-1 text-[8px] font-mono text-weak/40">+</span>
			<span class="absolute -bottom-1 -right-1 text-[8px] font-mono text-weak/40">+</span>

			<div class="flex items-center gap-2 text-[10px] font-mono text-weak uppercase tracking-widest">
				<span>[ ARCHIVE.INDEX // 03 ]</span>
				<span class="h-px w-8 bg-weak/20"></span>
				<span>{t("navigation.jotting").toUpperCase()}</span>
			</div>
			<h1 class="font-serif font-light text-3xl sm:text-4xl text-primary mt-1 select-text">
				{t("navigation.jotting")}
			</h1>
		</header>

		<Jotting client:load {locale} jottings={list} {tags} />
	</main>
</Base>
