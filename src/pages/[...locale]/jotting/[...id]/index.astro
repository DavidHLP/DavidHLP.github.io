---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import config from "$config";
import { contentStaticPaths } from "$utils/content";
import ContentDetail from "$layouts/ContentDetail.astro";

/**
 * Jotting detail page.
 *
 * The chrome (Base meta, header, sensitive wrapper, optional TOC, position
 * button) lives in `$layouts/ContentDetail.astro`. The layout closes the
 * "note has TOC + series, jotting does not" decision at the section seam
 * (`supportsToc` and the `articleSection` derivation), so this page is a
 * mirror of the note page with the section id swapped.
 */
export async function getStaticPaths() {
	return contentStaticPaths("jotting");
}

const { locale = config.i18n.defaultLocale } = Astro.params;
const { jotting } = Astro.props as { jotting: CollectionEntry<"jotting"> };

const { Content, headings, remarkPluginFrontmatter: frontmatter } = await render(jotting);
---

<ContentDetail {locale} section="jotting" entry={jotting} {Content} {headings} {frontmatter} />
