---
import config from "$config";
import { contentUrl, getPublishedByLocale, localeStaticPaths } from "$utils/content";
import Base from "$layouts/Base.astro";
import Note from "$components/Note.svelte";
import i18nit from "$i18n";

export const getStaticPaths = localeStaticPaths;

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

const notes = await getPublishedByLocale("note", locale);

// Standardize note structure
let list = notes.map(note => ({
	id: note.id,
	url: contentUrl(locale, "note", note.id),
	data: {
		title: note.data.title,
		timestamp: note.data.timestamp,
		series: note.data.series,
		tags: note.data.tags,
		sensitive: note.data.sensitive,
		top: note.data.top
	}
}));

// Extract all unique series and tags from the filtered notes
const series = Array.from(new Set(notes.map(note => note.data.series).filter((series): series is string => Boolean(series)))).sort();
const tags = Array.from(new Set(notes.flatMap(note => note.data.tags).filter((tag): tag is string => Boolean(tag)))).sort();
---

<Base title={t("navigation.note")} {locale}>
	<main class="flex flex-col grow py-4">
		<!-- Page Header -->
		<header class="flex flex-col gap-2 mb-10 border-b border-weak/10 pb-6 relative">
			<!-- Corner Marks -->
			<span class="absolute -bottom-1 -left-1 text-[8px] font-mono text-weak/40">+</span>
			<span class="absolute -bottom-1 -right-1 text-[8px] font-mono text-weak/40">+</span>

			<div class="flex items-center gap-2 text-[10px] font-mono text-weak uppercase tracking-widest">
				<span>[ ARCHIVE.INDEX // 02 ]</span>
				<span class="h-px w-8 bg-weak/20"></span>
				<span>{t("navigation.note").toUpperCase()}</span>
			</div>
		</header>

		<Note client:load {locale} notes={list} {series} {tags} />
	</main>
</Base>
