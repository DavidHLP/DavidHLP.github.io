---
import config from "$config";
import { collectFacets, getPublishedByLocale, localeStaticPaths, toCard } from "$utils/content";
import Base from "$layouts/Base.astro";
import ContentList from "$components/ContentList.svelte";
import ContentListingHeader from "$components/ContentListingHeader.astro";
import i18nit from "$i18n";

export const getStaticPaths = localeStaticPaths;

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

const notes = await getPublishedByLocale("note", locale);

// Route through the listing-card seam: one adapter, one shape, three callers.
const list = notes.map(note => toCard(note, "note", locale));

// Extract facets (series is only present in Note).
const { series, tags } = collectFacets(notes, true);
---

<Base title={t("navigation.note")} {locale}>
	<main class="flex flex-col grow py-4">
		<ContentListingHeader index={2} label={t("navigation.note")} />
		<ContentList client:load {locale} section="note" items={list} {series} {tags} />
	</main>
</Base>
