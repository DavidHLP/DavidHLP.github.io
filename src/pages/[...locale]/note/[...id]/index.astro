---
import { render } from "astro:content";
import type { CollectionEntry } from "astro:content";
import config from "$config";
import { contentStaticPaths } from "$utils/content";
import ContentDetail from "$layouts/ContentDetail.astro";

/**
 * Note detail page.
 *
 * The chrome (Base meta, header, sensitive wrapper, optional TOC, position
 * button) lives in `$layouts/ContentDetail.astro` behind the
 * `ContentDetailProps` interface. This file owns only what is *page-level*:
 * the `getStaticPaths` builder for the note collection, the props
 * extraction, the `render(entry)` call, and the layout invocation.
 *
 * Adding a third listable section is a near-mirror of this file: the only
 * differences are the section id passed to `contentStaticPaths` and the
 * variable destructured from `Astro.props`. The seam at the layout closes
 * the rest.
 */
export async function getStaticPaths() {
	return contentStaticPaths("note");
}

const { locale = config.i18n.defaultLocale } = Astro.params;
const { note } = Astro.props as { note: CollectionEntry<"note"> };

const { Content, headings, remarkPluginFrontmatter: frontmatter } = await render(note);
---

<ContentDetail {locale} section="note" entry={note} {Content} {headings} {frontmatter} />
