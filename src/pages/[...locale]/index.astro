---
import { render } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import config from "$config";
import { getPublishedByLocale, latestByTimestamp, listBySections, localeStaticPaths } from "$utils/content";
import { sectionLabel, ts } from "$utils/labels";
import Time from "$utils/time";
import Base from "$layouts/Base.astro";
import Heatmap from "$components/Heatmap.astro";
import TechBorder from "$components/TechBorder.astro";
import LatestCard from "$components/LatestCard.astro";
import Logo from "$icons/site-logo.svg";
import i18nit, { i18nData } from "$i18n";

export const getStaticPaths = localeStaticPaths;

const { locale = config.i18n.defaultLocale } = Astro.params;

const t = i18nit(locale);

// Profile card resolves through the i18n seam's `fallbackLocale` policy
// (ADR 0004 + Phase B of the architecture review): a key missing in the
// active locale transparently resolves to the configured fallback locale,
// so the page no longer needs to compose the fallback at the call site.
const profile = i18nData(locale).home?.profile;

// Resolve the localized prologue and author via the i18n seam so per-locale
// i18n entries fall back to the site-wide `site.config.ts` values (ADR 0004).
const prologue = t("home.prologue") ?? config.prologue;
const prologueAuthor = t("home.prologue_author") ?? config.prologueAuthor;

// Preface content for the current locale, sorted by timestamp (latest first).
// Routes through `getPublishedByLocale` so Preface shares the same locale-filter
// seam as Note and Jotting, and the input entry is never mutated.
const prefaces = (await getPublishedByLocale("preface", locale)).sort((a, b) => b.data.timestamp.getTime() - a.data.timestamp.getTime());

// Fetch + shape every listable card once. The seam in `src/utils/sections.ts`
// owns the listable-section iteration, the locale filter, and the `toCard`
// projection. The page reads the pool; both the "latest" pick and the
// heatmap consume the same array — no second fetch, no second shape pass.
// The previous version called `latestCard` (which re-fetched internally)
// and fetched `notes` / `jottings` separately for the heatmap inputs.
// Collapsing the two fetches into one is a pure locality win: change
// happens in one place, not three.
const cards = await listBySections(config.latest || "*", locale);
const latest = latestByTimestamp(cards);

// The most recent preface drives the preface panel.
const preface = prefaces[0];
// Render preface content if available, otherwise use an empty object.
const { Content } = preface ? await render(preface) : ({} as any);

// Resolve the localized unit label for the heatmap (day / week / month).
const heatmapUnit = config.heatmap?.unit || "day";
const unitLabel = ts(t, `home.unit.${heatmapUnit}`);
---

<Base title={ts(t, "navigation.home")} {locale}>
	<main class="flex flex-col gap-12 sm:gap-24 grow py-6 relative">
		<!-- Background subtle grid line -->
		<div class="absolute inset-y-0 start-1/4 border-s border-weak/5 hidden md:block pointer-events-none"></div>

		<header class="grid grid-cols-1 md:grid-cols-4 gap-8 items-start relative z-10">
			<div class="md:col-span-3 flex flex-col gap-4">
				<div class="flex items-center gap-2 text-[10px] font-mono text-weak uppercase tracking-widest">
					<span>[ PROLOGUE.INIT ]</span>
					<span class="h-px w-8 bg-weak/20"></span>
					<span>TALK_IS_CHEAP</span>
				</div>
				{prologue && (
					<div class="flex flex-col gap-2 max-w-2xl">
						<article class="font-serif font-light text-2xl sm:text-4xl leading-relaxed tracking-wide text-primary/90 select-text italic">
							"{prologue}"
						</article>
						{prologueAuthor && (
							<span class="text-xs font-mono text-weak self-end">
								— {prologueAuthor}
							</span>
						)}
					</div>
				)}
			</div>

			<div class="md:col-span-1 flex md:justify-end items-center">
				<div class="relative tech-border p-5 bg-background shadow-sm group">
					<TechBorder class="absolute inset-0 pointer-events-none" />
					<Logo width={70} class="text-primary opacity-80 group-hover:opacity-100 group-hover:scale-105 transition-all duration-300" />
					<span class="absolute -bottom-2.5 right-3 px-1.5 py-0.5 bg-background border border-weak/10 text-[8px] font-mono text-weak tracking-wider uppercase">
						[SYS.ACTIVE]
					</span>
				</div>
			</div>
		</header>

		<!-- Profile/Dossier Card -->
		<section class="grid grid-cols-1 md:grid-cols-4 gap-8 relative border-t border-weak/10 pt-8 select-text">
			<div class="md:col-span-1 flex flex-col gap-1">
				<span class="text-[10px] font-mono text-weak uppercase tracking-widest">[ {ts(t, "home.profileTag")} ]</span>
				<span class="text-[9px] font-mono text-remark">{ts(t, "home.profileBrief")}</span>
			</div>

			<div class="md:col-span-3 grid grid-cols-1 md:grid-cols-3 gap-6">
				<!-- Bio Column -->
				<div class="md:col-span-1 flex flex-col justify-between border-b md:border-b-0 md:border-r border-weak/10 pb-6 md:pb-0 md:pr-4">
					<div>
						<h3 class="text-xl font-serif font-light mb-1">{profile.name}</h3>
						<p class="text-xs font-mono text-weak uppercase tracking-wider">// {profile.title}</p>
						<div class="mt-4 space-y-1.5 text-xs text-secondary font-mono">
							{profile.meta.map((item: string) => (
								<div>{item}</div>
							))}
						</div>
					</div>
					<div class="mt-6">
						<a href={getRelativeLocaleUrl(locale, "/about")} class="text-[10px] font-mono text-primary hover:text-secondary tracking-wider transition-colors duration-150 uppercase flex items-center gap-1.5">
							<span>{profile.linkText}</span>
							<span>→</span>
						</a>
					</div>
				</div>

				<!-- Highlights Column -->
				<div class="md:col-span-2 flex flex-col gap-2">
					<h4 class="text-xs font-mono text-weak uppercase tracking-wider">// {profile.highlightsTitle}</h4>
					<ul class="list-disc pl-4 text-xs text-secondary space-y-2 leading-relaxed">
						{profile.highlights.map((item: string) => (
							<li set:html={item} />
						))}
					</ul>
				</div>
			</div>
		</section>

		{
			preface && (
				<section class="grid grid-cols-1 md:grid-cols-4 gap-8 relative border-y border-weak/10 py-8 dot-grid">
					<TechBorder marker="dot" size="tight" class="absolute inset-0 pointer-events-none" />

					<div class="md:col-span-1 flex flex-col gap-1">
						<span class="text-[10px] font-mono text-weak uppercase tracking-widest">{sectionLabel(t, 1, "home.section.preface")}</span>
						<span class="text-[9px] font-mono text-remark">{Time.toLocaleDateString(preface.data.timestamp, locale)}</span>
					</div>

					<div class="md:col-span-3 flex flex-col gap-4">
						<article class="markdown font-serif text-lg leading-relaxed select-text font-light max-w-3xl">
							<Content />
						</article>
						{preface.data.author && (
							<span class="text-xs font-mono text-weak max-w-3xl text-right pr-4">
								— {preface.data.author}
							</span>
						)}
						<div class="mt-2 flex justify-end">
							<a href={getRelativeLocaleUrl(locale, "/preface")} class="text-[10px] font-mono text-remark hover:text-primary tracking-wider transition-colors duration-150 uppercase flex items-center gap-1.5">
								<span>{ts(t, "home.viewPrefaceArchive")}</span>
								<span>→</span>
							</a>
						</div>
					</div>
				</section>
			)
		}

		{
			latest && (
				<footer class="grid grid-cols-1 lg:grid-cols-12 gap-8 items-stretch">
					<!-- Heatmap panel -->
					<div class="lg:col-span-7 relative tech-border p-6 bg-background/50 flex flex-col justify-between min-w-0">
						<TechBorder class="absolute inset-0 pointer-events-none" />

						<div class="flex items-center justify-between gap-4 mb-4 border-b border-weak/10 pb-2">
							<span class="text-[10px] font-mono text-weak uppercase tracking-widest">{sectionLabel(t, 2, "home.section.activity")}</span>
							<span class="text-[9px] font-mono text-remark">UNIT: {unitLabel}</span>
						</div>

						<div class="flex justify-center items-center py-4 overflow-x-auto min-w-0 no-scrollbar">
							<Heatmap {locale} {cards} />
						</div>
					</div>

					<!-- Latest release panel -->
					<div class="lg:col-span-5">
						<LatestCard entry={latest} {locale} />
					</div>
				</footer>
			)
		}
	</main>
</Base>
