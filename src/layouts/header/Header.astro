---
import { getRelativeLocaleUrl } from "astro:i18n";
import Icon from "$components/Icon.svelte";
import { monolocale } from "$config";
import i18nit from "$i18n";
import { ts } from "$utils/labels";
import Navigator from "./Navigator.svelte";
import ThemeSwitcher from "./ThemeSwitcher.astro";
import LanguagePicker from "./LanguagePicker.svelte";
import Menu from "./Menu.astro";

const { locale, title } = Astro.props;

const t = i18nit(locale);

/** Define navigation routes configuration */
const routes: { path: string; extra?: string[]; icon: `${string}--${string}`; label: string }[] = [
	{ label: ts(t, "navigation.home"), path: getRelativeLocaleUrl(locale), extra: [getRelativeLocaleUrl(locale, "/preface")], icon: "lucide--tent" },
	{ label: ts(t, "navigation.note"), path: getRelativeLocaleUrl(locale, "/note"), icon: "lucide--list" },
	{ label: ts(t, "navigation.jotting"), path: getRelativeLocaleUrl(locale, "/jotting"), icon: "lucide--feather" },
	{ label: ts(t, "navigation.about"), path: getRelativeLocaleUrl(locale, "/about"), icon: "lucide--at-sign" }
];

const route = Astro.url.pathname;
